# Feedback daemon
[org/sigxcpu/feedbackd]
profile='full'

# Squeekboard OSK scale
[sm/puri/Squeekboard]
scale-in-horizontal-screen-orientation=0.69999999999999996
scale-in-vertical-screen-orientation=0.69999999999999996

# Calls
[org/gnome/Calls]
auto-use-default-origins=true

# Chatty messaging
[sm/puri/Chatty]
indicate-unknown-contacts=true
render-attachments=true
request-sms-delivery-reports=true

# Location (kapalı varsayılan)
[org/gnome/system/location]
enabled=false
