# Phosh shell defaults
[sm/puri/phosh]
app-filter-mode=['adaptive']
shell-layout='device'
favorites=['org.gnome.Calls.desktop', 'sm.puri.Chatty.desktop', 'org.gnome.Epiphany.desktop', 'org.gnome.Contacts.desktop', 'org.gnome.clocks.desktop', 'org.gnome.Calculator.desktop', 'org.gnome.Nautilus.desktop', 'org.gnome.Settings.desktop']
enable-suspend=false
scale-to-fit=true

# Lockscreen
[sm/puri/phosh/lockscreen]
shuffle-keypad=true

# Notifications
[sm/puri/phosh/notifications]
wakeup-screen-urgency='critical'
